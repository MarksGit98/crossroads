; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] key=value

[application]

config/name="Crossroads"
config/description="Roguelike hex-grid deckbuilder board game"
run/main_scene="res://scenes/duel/DuelTestScene.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameManager="*res://autoloads/game_manager.gd"
RunData="*res://autoloads/run_data.gd"
CardDatabase="*res://autoloads/card_database.gd"
UnitDatabase="*res://autoloads/unit_database.gd"
TerrainDatabase="*res://autoloads/terrain_database.gd"
AudioManager="*res://autoloads/audio_manager.gd"
SaveSystem="*res://autoloads/save_system.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

select={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false)]
}

[rendering]

renderer/rendering_method="forward_plus"
