[node name="AxedMarauder" unique_id=741923001 instance=ExtResource("1_base")]
script = ExtResource("2_script")
## Lower than the default 2.5 because the AxeWarrior source frames are tight
## (~80px wide) — the creature-scale math divides hex_diameter by frame_width
## so a tight frame produces a large base_scale. 1.3 brings him visually in
## line with other Viking creatures whose frames are ~100-128px.
sprite_scale_factor = 1.3

